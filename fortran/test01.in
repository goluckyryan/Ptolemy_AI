HEADER  TEST01 -- FIRST SOME KEYWORD TESTS AND SOME ALLOCATOR TESTS
$
$  KEEP GOING IF THERE IS AN ERROR
$
$+ TSO
$
$  INITIAL CONDITIONS
$
$+ KEYWORDS  LISTKEYS
$
$  DEFINE SOMETHING IN EACH COMMON BLOCK
$
R0 = 1.2
L = 5
J = 3/2
NUCONLY
KEYWORDS
UNDEFINE R0
UNDEFINE J
UNDEFINE L
$+ KEYWORDS
$
$  TEST THE ALLOCATE COMMAND
$
PRINT 200001
ALLOCATE  JONES  1 2. 3.3 4.E+10  5.55E-15  60000  .000007
NSCATALOG
DUMP JONES
FREE JONES
NAMES
NEWPAGE
HEADER  TESTS OF BOUND STATE CALCULATIONS
PRINT 1
$+ PRINT = 9999999
$
$   FIRST NO SPIN-ORBIT  AND WITHOUT WHITAKER ASYMPTOPIA
$
SKIPASYMPTOPIA
ASYMPTOPIA = 10
CHANNEL  P+15N = 16O
WRITESTEP = .1    STEPSIZE = .1
NODES = 0   L = 1
R0 = 1.20  A=.65  V=60  RC0 = 1.20
$+ KEYWORDS
;
$+ NSCATALOG   PRINTWAVE    DUMPALL
$+ KEYWORDS
$+ NEWPAGE
$
$  NOW DO IT WITH THE WHITAKER TYPE FUNCITONS
$
CLEAR
WRITESTEP = 0
DOASYMPTOPIA   V = 60  ;
$+ WRITESTEP = .1  PRINTWAVE KEYWORDS  NSCATALOG
$+ NEWPAGE
$
$  NOW AN EXAMPLE USING S.O.
$
CLEAR
WRITESTEP = 0
CHANNEL:   N+16O = 17O(1/2- 3.12)
NODES = 2  L = 1
R0 = 1.28   A=.76   V=60
RC0 = 1.2
VSO = 6   RSO0 = 1.09   ASO = .6
$+ KEYWORDS
;
$+ WRITESTEP = .1  PRINTWAVE KEYWORDS  NSCATALOG
$+ DUMPALL
RESET  ECHO
$+ PRINT = 999999
$
$  ERSKIN'S BOUND STATE FAILURE
$
CHANNEL TI52 = 4HE + CA48
ASYMPTOPIA = 15
WRITESTEP = 0
NODES = 6
R0 = .87  A = .65   RC0 = .87
STEPSIZE = .05   ASYMPTOPIA = 10
V = 60  ;
$+ WRITESTEP = .1  PRINTWAVE KEYWORDS  NSCATALOG
$+ DUMPALL
WRITESTEP = 0
CLEAR  V = 10  ;
ASYMPTOPIA = 20  V=60  CLEAR  ;
$
$  AN ALL MOST UNBOUND STATE
$
E = -.01 ;
RETURN
